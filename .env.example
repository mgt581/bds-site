# --------------------------------------------------------------------------
# Database
# --------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/bds_seo_audit"

# --------------------------------------------------------------------------
# OpenAI (optional - enables AI-generated executive summaries)
# If omitted, a rule-based summary is generated instead.
# --------------------------------------------------------------------------
OPENAI_API_KEY="sk-..."

# --------------------------------------------------------------------------
# Resend (email delivery)
# --------------------------------------------------------------------------
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@bryantdigitalsolutions.com"
ADMIN_EMAIL="info@bryantdigitalsolutions.com"

# --------------------------------------------------------------------------
# Google PageSpeed Insights (optional - enables real Core Web Vitals data)
# If omitted, performance is estimated from page weight and response time.
# --------------------------------------------------------------------------
PAGESPEED_API_KEY=""

# --------------------------------------------------------------------------
# Admin dashboard
# --------------------------------------------------------------------------
ADMIN_PASSWORD="your-secure-admin-password"

# --------------------------------------------------------------------------
# Session signing secret (used to sign the admin auth cookie)
# --------------------------------------------------------------------------
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# --------------------------------------------------------------------------
# Public app URL (used in email links, must be reachable by recipients)
# --------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
